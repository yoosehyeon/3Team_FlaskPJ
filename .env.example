# ── Flask Backend (Cloudtype / Local) ─────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:6543/postgres
# ⚠️ 포트 반드시 6543 (Transaction mode / PgBouncer) 로컬과 무관하게 배포 시 필수

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... (서버 전용, 절대 프론트엔드 노출 금지)

TMAP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
ODSAY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_DATA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

FLASK_ENV=production          # 미설정 시 개발 모드, CORS 느슨하게 적용됨
FLASK_DEBUG=0                 # 프로덕션 배포 시에는 반드시 0

VITE_DOMAIN=https://[앱이름].netlify.app
# CORS 허용 도메인 — 로컬에선 5173 오픈, 배포 시엔 Netlify 도메인 기입 필수

# ── React Frontend (Netlify / Local) ──────────────────────────────────
VITE_API_URL=http://localhost:5000
# 프로덕션 배포 후: https://[앱이름].cloudtype.app 으로 교체 필수

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...(anon key만 허용, service role 기입 금지)
VITE_KAKAO_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
